SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=

# Goose (для миграций)
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=host=localhost port=5432 user= password= dbname= sslmode=disable
GOOSE_MIGRATION_DIR=./migrations

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_FORMATS=json